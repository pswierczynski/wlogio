# Skopiuj ten plik jako .env i uzupełnij swoimi danymi

# Wygeneruj losowy string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=zmien-na-losowy-string-minimum-32-znaki

# Connection string z Supabase:
# Project Settings → Database → Connection string → URI
# Zamień [YOUR-PASSWORD] na swoje hasło bazy
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Środowisko
FLASK_ENV=development
